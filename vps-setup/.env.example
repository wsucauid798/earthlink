# EarthLink — production environment
#
# Place this file at /home/earthlink/.env on the server.
# `chmod 600 ~/.env` after creating. Never commit real values.
#
# `docker compose` auto-loads this file when run from the directory it
# sits in (deploy user's home).

# --- Postgres ---------------------------------------------------------------

POSTGRES_USER=earthlink
POSTGRES_PASSWORD=__CHANGE_ME_LONG_RANDOM_STRING__
POSTGRES_DB=earthlink

# --- GHCR image source ------------------------------------------------------
# Owner of the package on ghcr.io. The image full name resolves to:
#   ghcr.io/${GHCR_OWNER}/earthlink-server:${EARTHLINK_SERVER_TAG}

GHCR_OWNER=wsucauid798

# Tag to deploy. Override to pin a specific version: sha-<short>, vX.Y.Z, or 'latest'.
EARTHLINK_SERVER_TAG=latest

# WebTransport endpoint used by the desktop client.
# Use a DNS-only hostname (grey cloud) that points directly to this VPS.
EARTHLINK_WT_PUBLIC_URL=https://wt.earthlink.yuxilabs.com/wt/world
